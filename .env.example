# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# xAI Grok
XAI_API_KEY=your_xai_api_key_here

# SMTP (works with Gmail, Outlook, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=you@gmail.com   # defaults to SMTP_USER if omitted

# Storage
DB_PATH=contacts.db        # relative path or absolute

# Behaviour
CONFIRM_BEFORE_SEND=false  # set to "true" to approve each email before sending

# Email template (optional overrides)
FOLLOW_UP_SUBJECT=Great meeting you!
FOLLOW_UP_TEMPLATE=Hi {name},\n\nIt was great meeting you! I'd love to stay in touch.\n\nBest regards
